{
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/seo", "permanent": false }
  ],
  "rewrites": [
    { "source": "/seo", "destination": "/" },
    { "source": "/seo/", "destination": "/" },
    { "source": "/seo/styles.css", "destination": "/styles.css" },
    { "source": "/seo/app.js", "destination": "/app.js" },
    { "source": "/seo/api/:path*", "destination": "/api/:path*" },
    { "source": "/seo/:path*", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
